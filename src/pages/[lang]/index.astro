---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, grades, languages, type Lang } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
---

<BaseLayout lang={lang}>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">{lang === "zh" ? "开放学习笔记" : "Open study notes"}</p>
      <h1>{lang === "zh" ? "走过的路，留给后来的人。" : "Notes from someone who has been there."}</h1>
      <p class="hero-copy">
        {lang === "zh"
          ? "学姐修读的是2023/2024学年及以后入学的电脑学理学士，Specialization是Business intelligence。希望如果我们有修读类似的课程，我可以帮到你~ 在这里可以按年级、学期和课程查找考试笔记与实用 Tips，我们一起努力！"
          : "I am studying for the BSc in Computer Science (intake from 2023/2024 onward), with a specialization in Business Intelligence. If you are taking similar courses, I hope these notes can help~ Browse exam notes and practical tips by year, semester, and course. Let's work hard together!"}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">{t.navYears}</p>
          <h2>{t.chooseYear}</h2>
        </div>
        <p>{t.chooseYearHint}</p>
      </div>
      <div class="grid">
        {grades.map((grade, index) => (
          <a class="card" href={`/${lang}/${grade.id}/`}>
            <span class="card-index">0{index + 1}<span class="arrow">↗</span></span>
            <h3>{grade.label[lang]}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
