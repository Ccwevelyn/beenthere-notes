---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy, courses, languages } from "../../../data/site";

export async function getStaticPaths() {
  const entries = await getCollection("notes", ({ data }) => data.published);
  return languages.flatMap((lang) =>
    entries.map((entry) => ({
      params: { lang, slug: entry.id },
      props: { entry, lang }
    }))
  );
}

const { entry, lang } = Astro.props;
const { Content, headings } = await render(entry);
const t = copy[lang];
const course = courses.find((item) => item.slug === entry.data.course);
const apiUrl = import.meta.env.PUBLIC_VIEWS_API_URL || "";
const articleSlug = entry.id;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <div class="article-shell">
    {toc.length > 0 && (
      <aside class="article-toc" aria-label={lang === "zh" ? "目录" : "Contents"}>
        <p class="toc-title">{lang === "zh" ? "目录" : "Contents"}</p>
        <nav>
          <ul>
            {toc.map((heading) => (
              <li class={`toc-depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <article class:list={["article-wrap", { "has-toc": toc.length > 0 }]}>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <span><a href={`/${lang}/`}>{lang === "zh" ? "首页" : "Home"}</a></span>
        {course && (
          <span>
            <a href={`/${lang}/${entry.data.grade}/${entry.data.semester}/${course.slug}/`}>
              {course.title[lang]}
            </a>
          </span>
        )}
        <span>{entry.data.title}</span>
      </nav>
      <span class="pill">{entry.data.type === "note" ? t.notes : t.tips}</span>
      <h1>{entry.data.title}</h1>
      {entry.data.description.trim() && <p class="hero-copy">{entry.data.description}</p>}
      <div class="article-meta">
        <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString(lang === "zh" ? "zh-CN" : "en-GB")}</time>
        <span>·</span>
        <span
          id="view-count"
          data-slug={articleSlug}
          data-api={apiUrl}
          data-suffix={t.views}
        >— {t.views}</span>
      </div>
      <div class="prose">
        <Content />
      </div>
      {entry.data.attachments.length > 0 && (
        <section class="attachments">
          <h2>{lang === "zh" ? "附件" : "Attachments"}</h2>
          <ul>
            {entry.data.attachments.map((attachment) => {
              const isImage = /\.(png|jpe?g|gif|webp|avif|svg)$/i.test(attachment.file);
              const isPdf = /\.pdf$/i.test(attachment.file);
              return (
                <li>
                  {isImage ? (
                    <figure>
                      <img src={attachment.file} alt={attachment.label} loading="lazy" />
                      <figcaption>{attachment.label}</figcaption>
                    </figure>
                  ) : (
                    <a href={attachment.file} target="_blank" rel="noopener">
                      <span class="attachment-icon" aria-hidden="true">{isPdf ? "PDF" : "FILE"}</span>
                      <span>{attachment.label}</span>
                      <span class="meta">{lang === "zh" ? "点击查看 / 下载" : "View / download"}</span>
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}
    </article>
  </div>
</BaseLayout>

<script>
  const counter = document.querySelector<HTMLElement>("#view-count");
  if (counter) {
    const { slug, api, suffix } = counter.dataset;
    const renderCount = (count: number) => {
      counter.textContent = `${count.toLocaleString()} ${suffix}`;
    };

    if (!api || !slug) {
      renderCount(Number(localStorage.getItem(`demo-views:${slug}`) || 128));
    } else {
      const key = `viewed:${slug}`;
      const method = sessionStorage.getItem(key) ? "GET" : "POST";
      fetch(`${api}/api/views/${encodeURIComponent(slug)}`, { method })
        .then((response) => {
          if (!response.ok) throw new Error("View service unavailable");
          return response.json();
        })
        .then((data) => {
          renderCount(data.views);
          sessionStorage.setItem(key, "1");
        })
        .catch(() => {
          counter.textContent = "";
        });
    }
  }

  const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>(".article-toc a")];
  const sections = tocLinks
    .map((link) => document.getElementById(decodeURIComponent(link.hash.slice(1))))
    .filter((node): node is HTMLElement => Boolean(node));

  if (tocLinks.length && sections.length && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible?.target.id) return;
        tocLinks.forEach((link) => {
          link.classList.toggle("is-active", link.hash === `#${visible.target.id}`);
        });
      },
      { rootMargin: "-20% 0px -65% 0px", threshold: [0, 0.25, 0.5, 1] }
    );
    sections.forEach((section) => observer.observe(section));
  }
</script>
