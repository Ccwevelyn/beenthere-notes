---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy, courses, languages } from "../../../data/site";

export async function getStaticPaths() {
  const entries = await getCollection("notes", ({ data }) => data.published);
  return languages.flatMap((lang) =>
    entries.map((entry) => ({
      params: { lang, slug: entry.id },
      props: { entry, lang }
    }))
  );
}

const { entry, lang } = Astro.props;
const { Content, headings } = await render(entry);
const t = copy[lang];
const course = courses.find((item) => item.slug === entry.data.course);
const articleSlug = entry.id;
// After Yuque heading normalize, body outline starts at H2; include H2–H4 in TOC.
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
const pdfAttachments = entry.data.attachments.filter((item) => /\.pdf$/i.test(item.file));
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <div class="article-shell">
    {toc.length > 0 && (
      <aside class="article-toc" aria-label={lang === "zh" ? "目录" : "Contents"}>
        <p class="toc-title">{lang === "zh" ? "目录" : "Contents"}</p>
        <nav>
          <ul>
            {toc.map((heading) => (
              <li class={`toc-depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <article class:list={["article-wrap", { "has-toc": toc.length > 0 }]}>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <span><a href={`/${lang}/`}>{lang === "zh" ? "首页" : "Home"}</a></span>
        {course && (
          <span>
            <a href={`/${lang}/${entry.data.grade}/${entry.data.semester}/${course.slug}/`}>
              {course.title[lang]}
            </a>
          </span>
        )}
        <span>{entry.data.title}</span>
      </nav>
      <span class="pill">{entry.data.type === "note" ? t.notes : t.tips}</span>
      <h1>{entry.data.title}</h1>
      {entry.data.description.trim() && <p class="hero-copy">{entry.data.description}</p>}
      <div class="article-meta">
        <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString(lang === "zh" ? "zh-CN" : "en-GB")}</time>
        <span>·</span>
        <span
          id="view-count"
          data-slug={articleSlug}
          data-suffix={t.views}
        >— {t.views}</span>
      </div>
      {pdfAttachments.length > 0 && (
        <div class="article-pdf-bar">
          {pdfAttachments.map((attachment) => (
            <a class="article-pdf-link" href={attachment.file} target="_blank" rel="noopener">
              {lang === "zh" ? "打开 PDF" : "Open PDF"}
              {attachment.label ? ` · ${attachment.label}` : ""}
            </a>
          ))}
        </div>
      )}
      <div class="prose">
        <Content />
      </div>
      {entry.data.attachments.some((item) => !/\.pdf$/i.test(item.file)) && (
        <section class="attachments" id="attachments">
          <h2>{lang === "zh" ? "附件" : "Attachments"}</h2>
          <ul>
            {entry.data.attachments
              .filter((attachment) => !/\.pdf$/i.test(attachment.file))
              .map((attachment) => {
              const isImage = /\.(png|jpe?g|gif|webp|avif|svg)$/i.test(attachment.file);
              return (
                <li>
                  {isImage ? (
                    <figure>
                      <img
                        src={attachment.file}
                        alt={attachment.label}
                        loading="lazy"
                        referrerpolicy="no-referrer"
                      />
                      <figcaption>{attachment.label}</figcaption>
                    </figure>
                  ) : (
                    <a href={attachment.file} target="_blank" rel="noopener">
                      <span class="attachment-icon" aria-hidden="true">FILE</span>
                      <span>{attachment.label}</span>
                      <span class="meta">{lang === "zh" ? "点击查看 / 下载" : "View / download"}</span>
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )}
    </article>
  </div>
</BaseLayout>
