---
import "../styles/global.css";
import { alternatePath, copy, grades, type Lang } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
  pathname?: string;
}

const {
  title = "BeenThere Notes",
  description = "Notes and practical advice from someone who has been there.",
  lang,
  pathname = Astro.url.pathname
} = Astro.props;
const t = copy[lang];
const fullTitle = title === "BeenThere Notes" ? title : `${title} — BeenThere Notes`;
const viewsApi = import.meta.env.PUBLIC_VIEWS_API_URL || "";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
  </head>
  <body data-api={viewsApi}>
    <header class="site-header">
      <nav class="container nav" aria-label="Main navigation">
        <a class="brand" href={`/${lang}/`}>
          <span class="brand-mark" aria-hidden="true"></span>
          <span>BeenThere Notes</span>
        </a>
        <div class="nav-links">
          <div class="nav-years">
            {grades.map((grade) => (
              <a href={`/${lang}/${grade.id}/`}>{grade.label[lang]}</a>
            ))}
          </div>
          <a href={`/${lang}/author/`}>{t.author}</a>
          <a href={`/${lang}/contribute/`}>{t.contribute}</a>
          <a class="lang-link" href={alternatePath(pathname, lang)}>{t.language}</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container footer-row">
        <span>© {new Date().getFullYear()} BeenThere Notes · <a href={`/${lang}/console/`}>{t.console}</a></span>
        <span>{lang === "zh" ? "走过，所以愿意留下路标。" : "I have been there, so I left a signpost."}</span>
      </div>
    </footer>
    <script>
      let tocObserver: IntersectionObserver | null = null;

      const apiBase = () => (document.body.dataset.api || "").replace(/\/$/, "");

      const bindViews = () => {
        const counter = document.querySelector<HTMLElement>("#view-count");
        if (!counter) return;
        const { slug, suffix } = counter.dataset;
        if (!slug) return;
        const renderCount = (count: number) => {
          counter.textContent = `${count.toLocaleString()} ${suffix}`;
        };
        // Every page open counts as one view.
        fetch(`${apiBase()}/api/views/${encodeURIComponent(slug)}`, { method: "POST" })
          .then((response) => {
            if (!response.ok) throw new Error("View service unavailable");
            return response.json();
          })
          .then((data) => {
            renderCount(Number(data.views || 0));
          })
          .catch(() => {
            counter.textContent = `— ${suffix || ""}`.trim();
          });
      };

      const bindConsole = () => {
        const shell = document.querySelector<HTMLElement>("#console");
        if (!shell) return;
        const rows = [...document.querySelectorAll<HTMLElement>("[data-article-row]")];
        const total = document.querySelector<HTMLElement>("#total-views");
        const status = document.querySelector<HTMLElement>("#connection-status");
        const tbody = shell.querySelector("tbody");
        const setCounts = (counts: Record<string, number>) => {
          let sum = 0;
          rows.forEach((row) => {
            const slug = row.dataset.slug || "";
            const count = counts[slug] ?? 0;
            row.dataset.views = String(count);
            const cell = row.querySelector<HTMLElement>("[data-view-cell]");
            if (cell) cell.textContent = count.toLocaleString();
            sum += count;
          });
          if (total) total.textContent = sum.toLocaleString();
          if (tbody) {
            [...rows]
              .sort((a, b) => Number(b.dataset.views || 0) - Number(a.dataset.views || 0))
              .forEach((row) => tbody.appendChild(row));
          }
        };
        fetch(`${apiBase()}/api/stats`)
          .then((response) => {
            if (!response.ok) throw new Error("Stats unavailable");
            return response.json();
          })
          .then((data) => {
            if (status) status.hidden = true;
            setCounts(data.views || {});
          })
          .catch(() => {
            if (status) {
              status.hidden = false;
              status.textContent =
                document.documentElement.lang === "zh"
                  ? "浏览量服务暂时不可用（本地预览或接口未就绪）。"
                  : "Views service unavailable.";
            }
            setCounts({});
          });
      };

      const bindToc = () => {
        tocObserver?.disconnect();
        tocObserver = null;
        const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>(".article-toc a[href^='#']")];
        tocLinks.forEach((link) => {
          link.addEventListener("click", (event) => {
            event.preventDefault();
            const id = decodeURIComponent(link.getAttribute("href")?.slice(1) || "");
            document.getElementById(id)?.scrollIntoView({ behavior: "smooth", block: "start" });
          });
        });
        const sections = tocLinks
          .map((link) => {
            const id = decodeURIComponent(link.getAttribute("href")?.slice(1) || "");
            return id ? document.getElementById(id) : null;
          })
          .filter((node): node is HTMLElement => Boolean(node));
        if (!tocLinks.length || !sections.length || !("IntersectionObserver" in window)) return;
        tocObserver = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (!visible?.target.id) return;
            tocLinks.forEach((link) => {
              const id = decodeURIComponent(link.getAttribute("href")?.slice(1) || "");
              link.classList.toggle("is-active", id === visible.target.id);
            });
          },
          { rootMargin: "-20% 0px -65% 0px", threshold: [0, 0.25, 0.5, 1] }
        );
        sections.forEach((section) => tocObserver?.observe(section));
      };

      const enhancePage = () => {
        bindToc();
        bindViews();
        bindConsole();
      };

      const swapTo = async (url: string, { push = true } = {}) => {
        const response = await fetch(url, { headers: { Accept: "text/html" } });
        if (!response.ok) {
          location.href = url;
          return;
        }
        const html = await response.text();
        const next = new DOMParser().parseFromString(html, "text/html");
        const nextMain = next.querySelector("main");
        const nextTitle = next.querySelector("title");
        if (!nextMain) {
          location.href = url;
          return;
        }
        const nextHeader = next.querySelector(".site-header");
        const nextFooter = next.querySelector("footer");
        const currentHeader = document.querySelector(".site-header");
        const currentFooter = document.querySelector("footer");
        if (nextHeader && currentHeader) currentHeader.replaceWith(nextHeader);
        document.querySelector("main")?.replaceWith(nextMain);
        if (nextFooter && currentFooter) currentFooter.replaceWith(nextFooter);
        if (nextTitle) document.title = nextTitle.textContent || document.title;
        const nextLang = next.documentElement.getAttribute("lang");
        if (nextLang) document.documentElement.setAttribute("lang", nextLang);
        if (push) history.pushState(null, "", url);
        window.scrollTo(0, 0);
        enhancePage();
      };

      document.addEventListener("click", (event) => {
        const link = (event.target as Element | null)?.closest?.("a[href]") as HTMLAnchorElement | null;
        if (!link || event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        if (link.target === "_blank" || link.hasAttribute("download")) return;

        const url = new URL(link.href, location.href);
        if (url.origin !== location.origin) return;
        if (url.pathname.startsWith("/admin")) return;
        if (url.hash && url.pathname === location.pathname) return;

        event.preventDefault();
        void swapTo(`${url.pathname}${url.search}`);
      });

      window.addEventListener("popstate", () => {
        void swapTo(`${location.pathname}${location.search}`, { push: false });
      });

      enhancePage();
    </script>
  </body>
</html>
