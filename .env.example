# Astro / Netlify（Site configuration → Environment variables）
SITE_URL=https://your-site.netlify.app

# 浏览量：默认走同域 Netlify Functions（/api/views、/api/stats），一般不用填
# PUBLIC_VIEWS_API_URL=

# 后台 GitHub 登录（必填）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 浏览量面板仅允许这些 GitHub 用户名登录（逗号分隔）
CONSOLE_GITHUB_USERS=Ccwevelyn
