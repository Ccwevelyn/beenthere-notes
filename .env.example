# Astro build（Netlify 上在 Site settings → Environment variables 配置）
SITE_URL=https://your-site.netlify.app
# 浏览量 API 稍后接入；现在可留空，站点与后台仍可用
PUBLIC_VIEWS_API_URL=

# 可选：以后自建浏览量 API（Render 等）时再用
# DATABASE_URL=postgresql://user:password@host/database
# ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:4321
# API_BASE_URL=https://your-api.example.com
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
